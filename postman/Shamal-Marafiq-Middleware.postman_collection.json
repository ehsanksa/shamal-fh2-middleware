{
  "info": {
    "name": "Shamal Middleware — Marafiq",
    "description": "Read-only FlightHub 2 integration demo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "apiKey", "value": "demo-marafiq-key-change-me" },
    { "key": "deviceSn", "value": "1581F6QAD23B00TEST01" },
    { "key": "taskId", "value": "0bbc74b4-5e5a-4390-9256-8e4ee08a241b" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "List devices",
      "request": {
        "method": "GET",
        "header": [{ "key": "X-Api-Key", "value": "{{apiKey}}" }],
        "url": "{{baseUrl}}/v1/marafiq/devices"
      }
    },
    {
      "name": "Device detail",
      "request": {
        "method": "GET",
        "header": [{ "key": "X-Api-Key", "value": "{{apiKey}}" }],
        "url": "{{baseUrl}}/v1/marafiq/devices/{{deviceSn}}"
      }
    },
    {
      "name": "Telemetry latest",
      "request": {
        "method": "GET",
        "header": [{ "key": "X-Api-Key", "value": "{{apiKey}}" }],
        "url": "{{baseUrl}}/v1/marafiq/devices/{{deviceSn}}/telemetry/latest"
      }
    },
    {
      "name": "List tasks",
      "request": {
        "method": "GET",
        "header": [{ "key": "X-Api-Key", "value": "{{apiKey}}" }],
        "url": "{{baseUrl}}/v1/marafiq/tasks"
      }
    },
    {
      "name": "Task detail",
      "request": {
        "method": "GET",
        "header": [{ "key": "X-Api-Key", "value": "{{apiKey}}" }],
        "url": "{{baseUrl}}/v1/marafiq/tasks/{{taskId}}"
      }
    },
    {
      "name": "Task media",
      "request": {
        "method": "GET",
        "header": [{ "key": "X-Api-Key", "value": "{{apiKey}}" }],
        "url": "{{baseUrl}}/v1/marafiq/tasks/{{taskId}}/media"
      }
    },
    {
      "name": "Task trajectory",
      "request": {
        "method": "GET",
        "header": [{ "key": "X-Api-Key", "value": "{{apiKey}}" }],
        "url": "{{baseUrl}}/v1/marafiq/tasks/{{taskId}}/trajectory"
      }
    },
    {
      "name": "Events",
      "request": {
        "method": "GET",
        "header": [{ "key": "X-Api-Key", "value": "{{apiKey}}" }],
        "url": "{{baseUrl}}/v1/marafiq/events"
      }
    },
    {
      "name": "Webhook FH2 (internal)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Webhook-Signature", "value": "dev-bypass" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event_type\": \"mission_completed\",\n  \"task_uuid\": \"0bbc74b4-5e5a-4390-9256-8e4ee08a241b\",\n  \"status\": \"success\"\n}"
        },
        "url": "{{baseUrl}}/webhooks/fh2"
      }
    }
  ]
}
