# Server
PORT=8080
HTTPS_REQUIRED=false
# Optional local HTTPS certs (PEM). Required when HTTPS_REQUIRED=true.
# HTTPS_KEY_PATH=/absolute/path/to/localhost-key.pem
# HTTPS_CERT_PATH=/absolute/path/to/localhost-cert.pem
NODE_ENV=development
LOG_LEVEL=info

# FlightHub 2 — set FH2_MODE=live when org key is configured
FH2_MODE=mock
# Regional API host (confirm in your FH2 org / DJI docs)
# US/international example; use es-flight-api-cn.djigate.com for China
FH2_BASE_URL=https://es-flight-api-us.djigate.com
FH2_ORG_TOKEN=
FH2_PROJECT_UUID=
FH2_LANGUAGE=en
# Optional: FH2 Livestream Sharing URL from FlightHub → Share (fallback when OpenAPI live-stream returns 403)
# FH2_LIVE_SHARE_URL=https://fh.dji.com/share/live/...
# Optional: deep link to your FH2 project cockpit (opens in new tab from platform)
# FH2_COCKPIT_URL=https://fh.dji.com/organization/.../project/...#/cockpit

# Marafiq API access
MARAFIQ_API_KEYS=demo-marafiq-key-change-me,marafiq-viewer,marafiq-admin
# Optional: default role per API key for non-UI clients (viewer|operator|admin)
MARAFIQ_API_KEY_ROLES=demo-marafiq-key-change-me:operator,marafiq-viewer:viewer,marafiq-admin:admin

# Shamal Platform login (preferred: set admin in .env)
admin_id=admin
admin_password=change-me-strong-password
# Optional operator / viewer accounts
# CC_OPERATOR_ID=operator
# CC_OPERATOR_PASSWORD=change-me
# CC_VIEWER_ID=viewer
# CC_VIEWER_PASSWORD=change-me
# CC_VIEWER_DISPLAY_NAME=Marafiq
# Optional public API base URL shown in viewer integration panel (e.g. https://api.shamalplatform.com)
# PUBLIC_API_BASE_URL=https://api.shamalplatform.com
# Viewer dashboard card visibility is stored per viewer in data/viewer-dashboard-permissions.json (managed via Admin Settings UI).
# Additional viewer accounts created in Admin Settings are stored in data/viewer-users.json.
# Viewer API integration tokens are stored in data/viewer-integrations.json (hashed + encrypted at rest).
# Or full list: username:password:role:apiKey (comma-separated)
# CC_USERS=admin:secret:admin:your-api-key
CC_SESSION_SECRET=change-me-cc-session-secret
# Comma-separated IPs; empty = allow all (dev only)
MARAFIQ_IP_ALLOWLIST=
# Phase 2: optional push of FH2 events to Marafiq CAFM (POST JSON)
MARAFIQ_EVENT_CALLBACK_URL=
MARAFIQ_EVENT_CALLBACK_SECRET=
WEBHOOK_SECRET=change-me-webhook-secret

# Database
# Port 5433 = local Homebrew Postgres (5432 may be used by another app on your Mac)
DATABASE_URL=postgres://shamal:shamal@localhost:5433/shamal_middleware

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
